# Copy to .env.local for local development and set the values below.
# In production (Vercel), set these in the project's Environment Variables.

# ---- NextAuth ----
# Secret used to sign session JWTs. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# Canonical URL of the deployment (no trailing slash).
#   Local dev:   http://localhost:3000
#   Production:  https://pomodoro-green-chi.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ---- Google OAuth ----
# Create an OAuth 2.0 Client ID (type: Web application) at:
#   https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origin:  <NEXTAUTH_URL>
# Authorized redirect URI:       <NEXTAUTH_URL>/api/auth/callback/google
#   e.g. https://pomodoro-green-chi.vercel.app/api/auth/callback/google
#        http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Access control (optional) ----
# Comma-separated allowlist of emails permitted to sign in.
# Leave empty to allow ANY Google account (each user gets isolated data).
#   e.g. ALLOWED_EMAILS=me@gmail.com,teammate@gmail.com
ALLOWED_EMAILS=

# ---- Data identity (optional) ----
# The owner's Google email is mapped to OWNER_USER_ID so the pre-existing
# Pomodoro history (stored under that id) is preserved after switching to OAuth.
OWNER_EMAIL=quocanhtophuong@gmail.com
OWNER_USER_ID=anhtpq

# ---- Database ----
MONGODB_URI=
